      "type": "number"
    },
    "loanerTotProj": {
      "type": "number",
      "description": "Total projected completions"
    },
    "effPct": {
      "type": "number",
      "description": "Computed eff %: loanerCmpl / loanerTotProj * 100"
    },
    "isMissing": {
      "type": "boolean",
      "description": "True if status is Missing"
    },
